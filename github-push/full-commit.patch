+  const { error } = await supabase
+    .from('company_pages')
+    .insert({
+      user_id: data.userId,
+      submission_id: data.submissionId,
+      company_name: data.companyName,
+      slug,
+      overall_score: data.overallScore,
+      description: data.description || null,
+    })
